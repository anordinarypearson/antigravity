rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - any authenticated user can read profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        // Allow updating follower/following counts
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['followerCount', 'followingCount'])
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // User subcollections (following, followers)
    // Users can write to their own following list AND to other users' followers list
    match /users/{userId}/{subcollection}/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        // Can write to own subcollections
        request.auth.uid == userId ||
        // Can write to someone else's followers subcollection if you're the follower
        (subcollection == 'followers' && request.auth.uid == docId) ||
        // Can write to someone else's following subcollection if they're following you
        (subcollection == 'following' && request.auth.uid == docId)
      );
    }

    // Chats - participants can read/write
    match /chats/{chatId} {
      // Allow create if you are one of the participants
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      // Allow read/update if you are a participant (or if the doc doesn't exist yet for existence checks)
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.participants);
      allow update, delete: if request.auth != null && request.auth.uid in resource.data.participants;
    }

    // Chat messages - only participants can see/send messages
    match /chats/{chatId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }
  }
}
